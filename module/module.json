{
  "id": "foundry-discord-bridge",
  "title": "Foundry-Discord Bridge",
  "description": "Chat en temps réel entre Foundry VTT et Discord",
  "version": "2.0.0",
  "authors": [
    { "name": "Gabryel & Jasra" }
  ],
  "compatibility": {
    "minimum": "11",
    "verified": "12",
    "maximum": "13"
  },
  "esmodules": ["foundry-discord-bridge.js"],
  "styles": ["foundry-discord-bridge.css"],
  "url": "https://github.com/Gabryel666/foundry-discord-bridge",
  "manifest": "https://raw.githubusercontent.com/Gabryel666/foundry-discord-bridge/main/module/module.json",
  "download": "https://github.com/Gabryel666/foundry-discord-bridge/releases/latest/download/module.zip",
  "settings": [
    {
      "key": "relayUrl",
      "name": "URL du relay",
      "hint": "Adresse WebSocket du serveur relay (ex: wss://votre-serveur:3120/foundry-bridge)",
      "scope": "world",
      "config": true,
      "type": "String",
      "default": ""
    },
    {
      "key": "enabled",
      "name": "Activer le bridge",
      "scope": "world",
      "config": true,
      "type": "Boolean",
      "default": true
    },
    {
      "key": "showDiscord",
      "name": "Afficher les messages Discord",
      "scope": "client",
      "config": true,
      "type": "Boolean",
      "default": true
    }
  ]
}
